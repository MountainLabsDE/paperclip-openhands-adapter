{
  "name": "@paperclipai/adapter-openhands-local",
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://github.com/MountainLabsDE/paperclip-openhands-adapter",
  "bugs": {
    "url": "https://github.com/MountainLabsDE/paperclip-openhands-adapter/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MountainLabsDE/paperclip-openhands-adapter.git"
  },
  "description": "Paperclip adapter for OpenHands (All-Hands-AI) - enables AI agents to execute code in sandboxed environments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "paperclip": {
    "adapterUiParser": "1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./ui-parser": "./src/ui/ui-parser.js",
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server/index.d.ts",
        "import": "./dist/server/index.js"
      },
      "./ui": {
        "types": "./dist/ui/index.d.ts",
        "import": "./dist/ui/index.js"
      },
      "./ui-parser": "./src/ui/ui-parser.js",
      "./cli": {
        "types": "./dist/cli/index.d.ts",
        "import": "./dist/cli/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "src/ui/ui-parser.js",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.428.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
