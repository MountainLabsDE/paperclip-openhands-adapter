# Paperclip API Key (required)
PAPERCLIP_API_KEY=

# LLM Provider API Key (at least one required)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Optional: OpenHands CLI path (defaults to "openhands")
OPENHANDS_CMD=openhands

# Optional: Default working directory
WORKSPACE_DIR=/tmp/openhands-workspace
